generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  ARCHIVED
}

enum OrderStatus {
  CREATED
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum EscrowStatus {
  NOT_STARTED
  FUNDS_LOCKED
  AWAITING_SHIPMENT
  IN_TRANSIT
  AWAITING_CONFIRMATION
  RELEASED
  REFUNDED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

model UserProfile {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId   String    @unique
  email         String    @unique
  displayName   String?
  username      String?   @unique
  avatarUrl     String?
  bio           String?
  role          UserRole  @default(BUYER)
  
  // Notification Preferences
  notificationOrderUpdates    Boolean @default(true)
  notificationDisputeUpdates  Boolean @default(true)
  notificationSellerActivity  Boolean @default(true)
  notificationMarketing       Boolean @default(false)
  notificationSecurity        Boolean @default(true)
  
  // Preferences
  preferredLanguage           String  @default("en")
  preferredCurrency           String  @default("USD")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sellerProfile SellerProfile?
  orders        Order[]       @relation("BuyerOrders")
  reviews       Review[]
  wishlist      Wishlist?
  cart          Cart?
  addresses     ShippingAddress[]
  disputes      Dispute[]     @relation("OpenedBy")
}

model SellerProfile {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userProfileId       String    @unique @db.ObjectId
  userProfile         UserProfile @relation(fields: [userProfileId], references: [id])
  storeName           String    @unique
  bio                 String?
  isVerified          Boolean   @default(false)
  ratingAverage       Float     @default(0)
  totalSales          Int       @default(0)
  payoutWalletAddress String?
  preferredPayoutNetwork String? @default("POLYGON")
  bannerImage         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  products            Product[]
  orders              Order[]   @relation("SellerOrders")
  reviews             Review[]
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
}

model Product {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  sellerProfileId   String        @db.ObjectId
  sellerProfile     SellerProfile @relation(fields: [sellerProfileId], references: [id])
  categoryId        String        @db.ObjectId
  category          Category      @relation(fields: [categoryId], references: [id])
  title             String
  slug              String        @unique
  shortDescription  String
  description       String
  price             Float
  paymentToken      String        @default("USDC")
  stock             Int           @default(1)
  condition         String        @default("NEW")
  status            ProductStatus @default(PUBLISHED)
  deliveryEstimate  String?
  shippingRegions   String[]
  metadataUri       String?
  contractProductId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  images            ProductImage[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  reviews           Review[]
}

model ProductImage {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  productId   String  @db.ObjectId
  product     Product @relation(fields: [productId], references: [id])
  url         String
  alt         String?
  sortOrder   Int     @default(0)
}

model Wishlist {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userProfileId String    @unique @db.ObjectId
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  productIds    String[]  @db.ObjectId
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Cart {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  userProfileId String     @unique @db.ObjectId
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  items         CartItem[]
}

model CartItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  cartId    String  @db.ObjectId
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
}

model ShippingAddress {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userProfileId String      @db.ObjectId
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  fullName      String
  phone         String
  country       String
  city          String
  region        String?
  addressLine1  String
  addressLine2  String?
  postalCode    String?
  isDefault     Boolean     @default(false)
}

model Order {
  id                      String       @id @default(auto()) @map("_id") @db.ObjectId
  buyerProfileId          String       @db.ObjectId
  buyerProfile            UserProfile  @relation("BuyerOrders", fields: [buyerProfileId], references: [id])
  sellerProfileId         String       @db.ObjectId
  sellerProfile           SellerProfile @relation("SellerOrders", fields: [sellerProfileId], references: [id])
  status                  OrderStatus  @default(CREATED)
  escrowStatus            EscrowStatus @default(NOT_STARTED)
  subtotal                Float
  platformFee             Float
  total                   Float
  paymentToken            String
  walletAddressUsed       String?
  shippingAddressSnapshot Json
  txHash                  String?
  contractOrderId         String?
  shipmentReference       String?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  completedAt             DateTime?
  disputedAt              DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  items                   OrderItem[]
  reviews                 Review[]
  disputes                Dispute[]
}

model OrderItem {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String  @db.ObjectId
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String  @db.ObjectId
  product        Product @relation(fields: [productId], references: [id])
  titleSnapshot  String
  imageSnapshot  String?
  quantity       Int
  unitPrice      Float
}

model Review {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId         String        @db.ObjectId
  order           Order         @relation(fields: [orderId], references: [id])
  productId       String        @db.ObjectId
  product         Product       @relation(fields: [productId], references: [id])
  buyerProfileId  String        @db.ObjectId
  buyerProfile    UserProfile   @relation(fields: [buyerProfileId], references: [id])
  sellerProfileId String        @db.ObjectId
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id])
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())
}

model Dispute {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId             String        @db.ObjectId
  order               Order         @relation(fields: [orderId], references: [id])
  openedByProfileId   String        @db.ObjectId
  openedByProfile     UserProfile   @relation("OpenedBy", fields: [openedByProfileId], references: [id])
  reason              String
  description         String
  evidenceUrls        String[]
  status              DisputeStatus @default(OPEN)
  resolution          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}
